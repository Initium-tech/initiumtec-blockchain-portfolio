# Copy this file to .env and fill in your own values.
# .env is git-ignored — NEVER commit real keys, and never reuse a key that
# has ever been pasted into a chat, screenshot, or repo.

# RPC endpoints — free tiers at https://www.alchemy.com or https://www.infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Private key of a DEDICATED deployer wallet (create a fresh one in MetaMask:
# Account menu -> Add account, then export its key). Fund it only with what
# deployment needs. Do NOT use your main wallet's key.
DEPLOYER_PRIVATE_KEY=

# For source verification — free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
